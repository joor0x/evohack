{
  "steps": [
    {
      "method": "POST",
      "url": "http://localhost:31337/rest/user/login",
      "headers": { "Content-Type": "application/json" },
      "body_template": "{\"email\": \"{payload}\", \"password\": \"12345678\"}",
      "captures": [ { "name": "token", "type": "json", "path": "authentication.token" } ]
    },
    {
      "method": "GET",
      "url": "http://localhost:31337/api/Feedbacks/",
      "headers": { "Authorization": "Bearer {token}" }
    }
  ]
}

